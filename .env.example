# superLLM Configuration
# Copy to .env and customize

# Mode: local, cloud, hybrid
SUPERLLM_MODE=local

# Server
SUPERLLM_HOST=127.0.0.1
SUPERLLM_PORT=8080

# Paths
SUPERLLM_DATA_DIR=~/.superllm
SUPERLLM_MODELS_DIR=~/.superllm/models

# Local inference
SUPERLLM_LOCAL_INFERENCE=true
SUPERLLM_LOCAL_N_CTX=2048
SUPERLLM_LOCAL_N_GPU_LAYERS=0
SUPERLLM_LOCAL_MAX_TOKENS=4096
SUPERLLM_LOCAL_VERBOSE=false

# Cloud routing
SUPERLLM_CLOUD_ROUTING=false
SUPERLLM_CLOUD_FALLBACK=true
SUPERLLM_CLOUD_REQUEST_TIMEOUT=120

# Smart Router (task-based routing)
SUPERLLM_ROUTER_STRATEGY=task
SUPERLLM_ROUTER_TASK_CLASSIFICATION=true
SUPERLLM_ROUTER_MAX_RAM_GB=32.0
SUPERLLM_ROUTER_AUTO_FALLBACK=true

# Agent configuration
SUPERLLM_AGENT_MAX_ITERATIONS=10
SUPERLLM_AGENT_DEFAULT_MODEL=auto
SUPERLLM_AGENT_MEMORY_MAX_MESSAGES=50
SUPERLLM_AGENT_TOOL_TIMEOUT=30

# Audio configuration
SUPERLLM_AUDIO_ENABLED=true
SUPERLLM_AUDIO_WHISPER_MODEL=small
SUPERLLM_AUDIO_DEVICE=cpu
SUPERLLM_AUDIO_COMPUTE_TYPE=int8
SUPERLLM_AUDIO_TTS_MODEL=bark
SUPERLLM_AUDIO_SAMPLE_RATE=24000

# Performance
SUPERLLM_MODEL_CACHE_ENABLED=true
SUPERLLM_MODEL_CACHE_MAX_GB=8.0
SUPERLLM_MODEL_LAZY_LOAD=true

# Auth
SUPERLLM_AUTH_ENABLED=false
SUPERLLM_API_KEY=

# HuggingFace Hub (for authenticated downloads and gated models)
SUPERLLM_HF_TOKEN=
SUPERLLM_HF_USERNAME=

# API Keys for cloud providers
SUPERLLM_OPENAI_API_KEY=
SUPERLLM_ANTHROPIC_API_KEY=
SUPERLLM_GOOGLE_API_KEY=

# UI
SUPERLLM_UI_ENABLED=true
SUPERLLM_UI_DEV_MODE=false

# Defaults
SUPERLLM_DEFAULT_MODEL=llama-3.2-1b
SUPERLLM_MODEL_PULL_TIMEOUT=600
